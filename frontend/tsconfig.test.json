{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": "/tmp/storagetron-frontend-test-dist",
    "rootDir": ".",
    "incremental": false,
    "types": ["node"]
  },
  "include": [
    "lib/api.ts",
    "lib/export-assets.ts",
    "lib/item-entry.ts",
    "lib/location.ts",
    "lib/api-proxy.ts",
    "lib/scan.ts",
    "lib/utils.ts",
    "tests/**/*.test.ts"
  ],
  "exclude": ["node_modules", ".next"]
}
