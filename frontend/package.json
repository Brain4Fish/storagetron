    "next": "^15.5.15",
    "qrcode": "1.5.4",
    "qrcode.react": "4.2.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
